# Optional RPC overrides. Defaults come from the official GIWA connect docs
# (https://docs.giwa.io/get-started/connect-to-giwa.md), so the app runs with no .env at all.
VITE_GIWA_RPC_URL=https://sepolia-rpc.giwa.io
# Flashblocks endpoint (200ms preconfirmations) — https://docs.giwa.io/network-information/flashblocks.md
VITE_GIWA_FLASHBLOCKS_RPC_URL=https://sepolia-rpc-flashblocks.giwa.io
