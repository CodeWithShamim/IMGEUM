# ---------------------------------------------------------------------------
# GIWA network — all values from https://docs.giwa.io/get-started/connect-to-giwa.md
# ---------------------------------------------------------------------------
GIWA_SEPOLIA_RPC_URL=https://sepolia-rpc.giwa.io
GIWA_SEPOLIA_FLASHBLOCKS_RPC_URL=https://sepolia-rpc-flashblocks.giwa.io

# Blockscout verification — https://docs.giwa.io/get-started/smart-contract/develop/foundry.md
BLOCKSCOUT_API_URL=https://sepolia-explorer.giwa.io/api
BLOCKSCOUT_API_KEY=

# ---------------------------------------------------------------------------
# Deployment
# ---------------------------------------------------------------------------
# Owner of the deployed contracts (a multisig in production). Defaults to the deployer.
PROTOCOL_OWNER=

# DOJANG_MODE: "mock" (demo — deploys MockDojangScroll with open enrollment)
#              "live" (wires the real DojangScroll predeploy)
DOJANG_MODE=mock

# ATTESTER_MODE: "faucet" (GIWA Sepolia testnet-faucet attester — demo-obtainable)
#                "upbit"  (Upbit Korea KYC attester — production)
ATTESTER_MODE=faucet

# Import the deployer key once with:  cast wallet import deployer --interactive
# then pass --account deployer to forge script (never put a raw key in this file).
